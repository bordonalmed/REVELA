# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Obrigatório para webhook Hotmart (libera Pro/Premium automaticamente)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Hotmart → POST /api/webhooks/hotmart (mesmo token na URL ?hottok= ou no body)
HOTMART_WEBHOOK_TOKEN=seu_token_secreto
# IDs numéricos dos produtos na Hotmart (separados por vírgula)
HOTMART_PRO_PRODUCT_IDS=1234567
HOTMART_PREMIUM_PRODUCT_IDS=7654321

# Opcional: loga payload truncado no servidor para ajustar o parser (desligar depois)
# HOTMART_WEBHOOK_DEBUG=1